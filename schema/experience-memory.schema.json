{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/agent-experience-ledger/experience-memory.schema.json",
  "title": "Agent Experience Memory",
  "type": "object",
  "required": [
    "schema_version",
    "title",
    "date",
    "source_agent",
    "status",
    "category",
    "tags",
    "confidence",
    "privacy"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "title": {
      "type": "string",
      "minLength": 8,
      "maxLength": 120
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "source_agent": {
      "type": "string",
      "enum": ["codex", "claude", "unknown"]
    },
    "status": {
      "type": "string",
      "enum": ["candidate", "promoted", "rejected"]
    },
    "category": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{1,39}$"
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "maxItems": 10,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]{1,39}$"
      }
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "repo": {
      "type": "string",
      "maxLength": 120
    },
    "branch": {
      "type": "string",
      "maxLength": 120
    },
    "capture_request_id": {
      "type": "string",
      "pattern": "^capture-[0-9]{8}-[0-9]{6}-[a-z0-9-]{1,80}$",
      "maxLength": 120
    },
    "source_session_id": {
      "type": "string",
      "maxLength": 120
    },
    "source_turn_id": {
      "type": "string",
      "maxLength": 120
    },
    "source_repo": {
      "type": "string",
      "maxLength": 120
    },
    "source_cwd": {
      "type": "string",
      "maxLength": 500
    },
    "privacy": {
      "type": "object",
      "required": ["contains_raw_transcript", "contains_secrets", "redaction_notes"],
      "additionalProperties": false,
      "properties": {
        "contains_raw_transcript": {
          "type": "boolean",
          "const": false
        },
        "contains_secrets": {
          "type": "boolean",
          "const": false
        },
        "redaction_notes": {
          "type": "string",
          "maxLength": 500
        }
      }
    },
    "reviewed_at": {
      "type": "string",
      "format": "date-time"
    },
    "reviewer": {
      "type": "string",
      "maxLength": 80
    },
    "rejection_reason": {
      "type": "string",
      "maxLength": 500
    }
  }
}
